// Schéma Prisma — cf. docs/ARCHITECTURE.md §6 (modèle de données).
// Taxonomie centrale : Level × Stream × Subject — épine dorsale du catalogue et du SEO.

generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum ExamType {
  NATIONAL
  REGIONAL
  BLANC
  CNC
  CONCOURS
}

enum ExamSession {
  NORMALE
  RATTRAPAGE
}

enum ResourceLanguage {
  FR
  AR
  EN
}

enum Role {
  ELEVE
  ADMIN
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

/// Auth.js v5, sessions JWT + comptes credentials (cf. ARCHITECTURE.md §9).
model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  name         String
  role         Role       @default(ELEVE)
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  auditLogs    AuditLog[]

  // Préférences choisies pendant l'onboarding élève — slugs plutôt que FK :
  // le profil survit si un niveau/filière est renommé ou supprimé du catalogue.
  levelSlug   String?
  streamSlug  String?
  onboardedAt DateTime?

  @@map("users")
}

/// Traçabilité des actions admin (créer/modifier/supprimer du contenu) —
/// permet de savoir qui a fait quoi et de revenir sur une erreur.
model AuditLog {
  id         String      @id @default(cuid())
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId     String
  action     AuditAction
  entityType String // "Exam" | "Stream" | "Subject" | "Level" | "User"
  entityId   String
  entityLabel String // libellé lisible (titre de l'examen, etc.) pour l'affichage du journal
  metadata   Json?
  createdAt  DateTime    @default(now())

  @@index([createdAt])
  @@index([userId])
  @@map("audit_logs")
}

/// Compteur de limitation de débit sur les actions sensibles (connexion,
/// téléchargements) — cf. ARCHITECTURE.md §9. Une ligne par (clé, fenêtre).
model RateLimitBucket {
  key         String   @id // ex: "login:ip:1.2.3.4" ou "login:email:x@y.com"
  count       Int      @default(1)
  windowStart DateTime @default(now())

  @@map("rate_limit_buckets")
}

model Level {
  id          String   @id @default(cuid())
  slug        String   @unique
  nameFr      String
  nameAr      String
  nameEn      String
  shortNameFr String
  shortNameAr String
  shortNameEn String
  descFr      String
  descAr      String
  descEn      String
  streams     Stream[]
  exams       Exam[]

  @@map("levels")
}

model Stream {
  id       String    @id @default(cuid())
  slug     String
  nameFr   String
  nameAr   String
  nameEn   String
  order    Int       @default(0) // position d'affichage au sein du niveau (admin: déplacer)
  level    Level     @relation(fields: [levelId], references: [id], onDelete: Cascade)
  levelId  String
  subjects Subject[] @relation("StreamSubjects")
  exams    Exam[]

  @@unique([levelId, slug])
  @@map("streams")
}

model Subject {
  id      String   @id @default(cuid())
  slug    String   @unique
  nameFr  String
  nameAr  String
  nameEn  String
  icon    String // clé vers components/icons.tsx (SUBJECT_ICONS)
  streams Stream[] @relation("StreamSubjects")
  exams   Exam[]

  @@map("subjects")
}

/// Un examen = une unité pédagogique (cf. ARCHITECTURE.md §6). Le champ
/// `language` porte la langue de la ressource elle-même (un examen en arabe
/// n'est pas une traduction).
model Exam {
  id             String            @id @default(cuid())
  title          String
  level          Level             @relation(fields: [levelId], references: [id])
  levelId        String
  stream         Stream            @relation(fields: [streamId], references: [id])
  streamId       String
  subject        Subject           @relation(fields: [subjectId], references: [id])
  subjectId      String
  type           ExamType
  year           Int
  session        ExamSession
  language       ResourceLanguage
  durationMin    Int
  hasCorrection  Boolean           @default(false)
  pdfUrl         String? // sujet officiel vérifié (CNEE ou autre)
  correctionUrl  String? // corrigé officiel vérifié
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([levelId, subjectId, type, year])
  @@map("exams")
}
